{
  "name": "jarbas",
  "version": "0.1.0",
  "description": "Assistente pessoal modular no WhatsApp",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/index.ts",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "testar:cerebro": "node --env-file=.env --import tsx src/testes/testar-cerebro.ts",
    "testar:link": "node --import tsx src/testes/testar-link.ts",
    "testar:db": "JARBAS_DB=:memory: node --import tsx src/testes/testar-db.ts",
    "testar:lembrete": "node --env-file=.env --import tsx src/testes/testar-lembrete.ts",
    "testar:gasto": "node --env-file=.env --import tsx src/testes/testar-gasto.ts",
    "testar:roteador": "JARBAS_DB=:memory: node --env-file=.env --import tsx src/testes/testar-roteador.ts",
    "testar:relatorio": "JARBAS_DB=:memory: node --import tsx src/testes/testar-relatorio.ts",
    "testar:consulta": "JARBAS_DB=:memory: node --import tsx src/testes/testar-consulta.ts",
    "testar:remedio": "JARBAS_DB=:memory: node --import tsx src/testes/testar-remedio.ts",
    "testar:verificar": "JARBAS_DB=:memory: node --import tsx src/testes/testar-verificar-remedios.ts",
    "testar:confirmar": "JARBAS_DB=:memory: node --import tsx src/testes/testar-confirmar-remedio.ts",
    "testar:calorias": "JARBAS_DB=:memory: node --env-file=.env --import tsx src/testes/testar-calorias.ts",
    "testar:resumo-calorias": "JARBAS_DB=:memory: node --import tsx src/testes/testar-resumo-calorias.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode-terminal": "^0.12.2",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "openai": "^6.48.0",
    "pino": "^10.3.1"
  }
}
