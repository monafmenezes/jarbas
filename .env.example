# Copie para .env e preencha. O .env NÃO vai pro git.

# Chave da API da OpenAI (usada nas Fases 1-3: resumo, intenção, transcrição e visão)
# Obs: o "cérebro" fica atrás de uma interface — dá pra trocar por outro provedor depois.
OPENAI_API_KEY=

# Contatos que podem falar com o Jarbas (com DDI+DDD, só dígitos), separados por
# vírgula — ex: 5583999999999,5583988888888. Você e quem você quiser liberar.
CONTATOS_AUTORIZADOS=
